{
  "manifest_version": 3,
  "name": "오답노트 - AI 지식 관리",
  "version": "1.0.0",
  "description": "웹 페이지의 텍스트를 오답노트에 바로 전송하여 AI와 대화하세요.",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
